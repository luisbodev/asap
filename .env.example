# Webhook n8n — validar POST /api/monitoring
N8N_WEBHOOK_SECRET=

# Webhook n8n — publicar en Instagram al aprobar post
N8N_INSTAGRAM_WEBHOOK_URL=https://tu-instancia-n8n.com/webhook/instagram-post

# OpenAI — solo servidor, Fase 3+
OPENAI_API_KEY=

# Meta Graph API — solo servidor, Fase 5+
META_ACCESS_TOKEN=
META_PAGE_ID=

# Modo demo: true = simular aunque existan keys
USE_MOCK_APIS=true

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
